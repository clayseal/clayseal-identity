# AgentAuth identity backend -- DEPLOYABLE third-party runtime dependency inputs.
#
# The internal `agentauth-core` distribution is installed from its built wheel in
# the deploy image (it is not published to PyPI), so it is intentionally NOT in
# this file. This locks only the third-party runtime tree.
#
# Compile a hash-pinned lock with either:
#   uv pip compile deploy/requirements.in --generate-hashes \
#       --python-version 3.13 -o deploy/requirements.lock
#   # or, with pip-tools:
#   pip-compile --generate-hashes deploy/requirements.in -o deploy/requirements.lock
#
# Install in the image with:
#   pip install --require-hashes -r deploy/requirements.lock

# --- runtime deps mirrored from agentauth-identity/pyproject.toml ---
