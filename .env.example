# Clay Seal identity service — production-oriented environment template.
# Copy to .env and fill in values before deploying.

CLAYSEAL_ENV=production
CLAYSEAL_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/clayseal
CLAYSEAL_MANAGE_SCHEMA=alembic
CLAYSEAL_ADMIN_API_KEY=
CLAYSEAL_SECRET_ENCRYPTION_PROVIDER=aws_kms
CLAYSEAL_AWS_KMS_KEY_ID=
CLAYSEAL_HTTP_ALLOWED_HOSTS=idp.example.com
CLAYSEAL_CORS_ORIGINS=https://app.example.com
CLAYSEAL_RATE_LIMIT_ENABLED=1
CLAYSEAL_TRUST_PROXY_HEADERS=1
CLAYSEAL_MTLS_ENABLED=0
CLAYSEAL_TLS_CA_BUNDLE=
