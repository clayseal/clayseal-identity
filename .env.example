# Clay Seal identity service — production-oriented environment template.
# Copy to .env and fill in values before deploying.

AGENTAUTH_ENV=production
AGENTAUTH_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/agentauth
AGENTAUTH_MANAGE_SCHEMA=alembic
AGENTAUTH_ADMIN_API_KEY=
AGENTAUTH_SECRET_ENCRYPTION_PROVIDER=aws_kms
AGENTAUTH_AWS_KMS_KEY_ID=
AGENTAUTH_HTTP_ALLOWED_HOSTS=idp.example.com
AGENTAUTH_CORS_ORIGINS=https://dashboard.example.com
AGENTAUTH_RATE_LIMIT_ENABLED=1
AGENTAUTH_TRUST_PROXY_HEADERS=1
AGENTAUTH_MTLS_ENABLED=0
AGENTAUTH_TLS_CA_BUNDLE=
