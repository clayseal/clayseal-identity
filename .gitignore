# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
.python-version

# Node (js/ integration packages)
node_modules/
package-lock.json
js/**/test/fixture.json

# Virtual environments
.venv/
.venv-*/
venv/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Coverage
.coverage
.coverage.*
coverage.json
coverage.xml
htmlcov/
lcov.info

# Local dev data (SQLite dev store, env files)
.env
*.db
*.sqlite

# TLS / signing key material — never commit
certs/*.pem
certs/*.json
!certs/.gitkeep
keys/signing/
*.key
**/keys/*.pem
**/.clayseal/keys/
*.ed25519.pem
*_private.pem

# IDE / OS / misc
.idea/
.vscode/
.cursor/mcp.json
*.swp
*.log
.DS_Store

# Claude Code session/tooling
.claude/
